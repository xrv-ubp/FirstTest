# Data sources
# ---------------------------------------------------------------------------
def _as_pandas(obj):
    """Coerce whatever blp.bdh returns (pandas / polars / pyarrow / dict) into a
    pandas DataFrame with a DatetimeIndex. Polars .columns is a list and polars
    has no .copy(), which is what broke the earlier pandas-only assumptions."""
    if not isinstance(obj, pd.DataFrame):
        if hasattr(obj, "to_pandas"):              # polars / pyarrow Table
            obj = obj.to_pandas()
        else:
            obj = pd.DataFrame(obj)
    obj = obj.copy()
    if not isinstance(obj.index, pd.DatetimeIndex):
        dt = [c for c in obj.columns if str(obj[c].dtype).startswith("datetime")]
        if not dt:
            for nm in ("date", "Date", "DATE", "Dates", "index", "Index"):
                if nm in obj.columns:
                    dt = [nm]; break
        if not dt and len(obj.columns):            # last resort: parse first column
            first = obj.columns[0]
            try:
                obj[first] = pd.to_datetime(obj[first]); dt = [first]
            except Exception:
                dt = []
        if dt:
            obj = obj.set_index(dt[0])
    return obj


def fetch_bloomberg(tenor, start, end, has10):
    """Robust to xbbg returning pandas OR polars/pyarrow, and to any column
    structure (MultiIndex, flat Index, plain list). Batched pull first; if the
    column mapping fails, fall back to per-ticker pulls."""
    from xbbg import blp
    tk = bbg_smile_tickers(tenor)
    if not has10:
        tk = {k: v for k, v in tk.items() if "10" not in k.split("_")[1]}
    inv = {v: k for k, v in tk.items()}

    def _flatten(cols):                            # list / Index / MultiIndex -> list
        return [c[0] if isinstance(c, tuple) else c for c in list(cols)]

    # --- primary: one batched pull ---
    try:
        raw0 = blp.bdh(list(tk.values()), "PX_LAST", start, end)
        _log(f"   blp.bdh returned {type(raw0).__module__}.{type(raw0).__name__}")
        raw = _as_pandas(raw0)
        raw.columns = _flatten(raw.columns)
        raw = raw.rename(columns=inv)
        keep = [k for k in tk if k in raw.columns]
        if len(keep) >= max(6, len(tk) // 2):
            _log(f"   batched pull mapped {len(keep)}/{len(tk)} columns")
            return raw[keep].apply(pd.to_numeric, errors="coerce")
        _log(f"   batched mapped only {len(keep)}/{len(tk)}; per-ticker fallback. "
             f"cols: {list(raw.columns)[:6]}")
    except Exception as e:
        _log(f"   batched pull failed ({e!r}); per-ticker fallback.")

    # --- fallback: pull each ticker individually (immune to shape) ---
    series = {}
    for name, ticker in tk.items():
        s = _as_pandas(blp.bdh(ticker, "PX_LAST", start, end))
        val = None
        for c in s.columns:                        # first column that is actually numeric
            col = pd.to_numeric(s[c], errors="coerce")
            if col.notna().any():
                val = col; break
        series[name] = val if val is not None else pd.Series(dtype=float)
        _log(f"   pulled {name:<12s} ({ticker}): {int(series[name].notna().sum())} obs")
    return pd.DataFrame(series).sort_index()

def load_csv(path):
    return pd.read_csv(path, index_col=0, parse_dates=True).sort_index()

def make_demo_smile(n_years=12, seed=11, convex=True, inject_spread=-0.10):
    """Triangle spots with an injected ATM correlation premium, plus skew/convexity
    smiles. With convex=False (flat smile) VR must reproduce the ATM result."""
    rng = np.random.default_rng(seed)
    n = int(n_years * ANNUALIZATION)
    idx = pd.bdate_range("2010-01-01", periods=n)
    rho_real = -0.30 + 0.15 * np.sin(np.linspace(0, 6 * np.pi, n))
    base_vol = 0.09 + 0.04 * np.abs(np.sin(np.linspace(0, 3 * np.pi, n)))
    r1 = np.empty(n); r2 = np.empty(n)
    for t in range(n):
        s = base_vol[t] / np.sqrt(ANNUALIZATION)
        cov = np.array([[s * s, rho_real[t] * s * s], [rho_real[t] * s * s, s * s]])
        r1[t], r2[t] = rng.multivariate_normal([0, 0], cov)
    p1 = 1.30 * np.exp(np.cumsum(r1)); p2 = 110.0 * np.exp(np.cumsum(r2)); pc = p1 * p2
    a1 = base_vol + 0.005; a2 = base_vol + 0.005
    rho_imp = np.clip(rho_real + inject_spread, -0.999, 0.999)
    ac = np.sqrt(a1 ** 2 + a2 ** 2 + 2 * rho_imp * a1 * a2)
    out = {}
    skew = {BASE1: -0.4, BASE2: -0.8, CROSS: -1.2} if convex else {p: 0.0 for p in PAIRS}
    conv = {BASE1: 0.2, BASE2: 0.3, CROSS: 0.4} if convex else {p: 0.0 for p in PAIRS}
    for p, atm, spot in [(BASE1, a1, p1), (BASE2, a2, p2), (CROSS, ac, pc)]:
        out[f"{p}_atm"] = atm * 100
        out[f"{p}_rr25"] = np.full(n, skew[p]); out[f"{p}_bf25"] = np.full(n, conv[p])
        out[f"{p}_rr10"] = np.full(n, 1.8 * skew[p]); out[f"{p}_bf10"] = np.full(n, 3.0 * conv[p])
        out[f"{p}_spot"] = spot
    return pd.DataFrame(out, index=idx)

# ---------------------------------------------------------------------------
# Unit tests (run with --selftest)
# ---------------------------------------------------------------------------
def selftest():
    F, T = 1.10, 21 / ANNUALIZATION
    atm = 0.09
    Kf, Vf = build_smile_points(F, T, atm, 0.0, 0.0, 0.0, 0.0)          # flat
    vf = np.sqrt(fair_variance(F, T, Kf, Vf))
    assert abs(vf - atm) < 1.5e-3, f"flat smile: VS vol {vf:.5f} != atm {atm}"
    Kc, Vc = build_smile_points(F, T, atm, -0.004, 0.003, -0.007, 0.009)  # skew+convex
    vc = np.sqrt(fair_variance(F, T, Kc, Vc))
    assert vc > atm + 5e-4, f"convex smile: VS vol {vc:.5f} not > atm"
    # flat-smile triangle: VR rho must equal ATM rho
    a1, a2, rho = 0.09, 0.11, -0.35
    ac = np.sqrt(a1 ** 2 + a2 ** 2 + 2 * rho * a1 * a2)
    K = {}
    for nm, a, Fp in [("b1", a1, 1.10), ("b2", a2, 110.0), ("c", ac, 121.0)]:
        Ks, Vs = build_smile_points(Fp, T, a, 0.0, 0.0, 0.0, 0.0)
        K[nm] = fair_variance(Fp, T, Ks, Vs)
    rho_vr = (K["c"] - K["b1"] - K["b2"]) / (2 * np.sqrt(K["b1"] * K["b2"]))
    assert abs(rho_vr - rho) < 3e-3, f"flat triangle: VR rho {rho_vr:+.4f} != ATM rho {rho:+.4f}"
    print("SELFTEST PASSED")
    print(f"  flat-smile VS vol      = {vf:.5f}  (atm {atm})")
    print(f"  convex-smile VS vol    = {vc:.5f}  (> atm, convexity lifts variance)")
    print(f"  flat-triangle VR rho   = {rho_vr:+.4f}  (target {rho:+.4f})")

def main():
    ap = argparse.ArgumentParser(description="Step 2 rescue — variance-replicating implied correlation")
    ap.add_argument("--source", choices=["bloomberg", "csv", "demo"], default="demo")
    ap.add_argument("--tenors", default="1M,3M")
    ap.add_argument("--start", default="2007-01-01")
    ap.add_argument("--end", default="2025-01-01")
    ap.add_argument("--csv", default=None)
    ap.add_argument("--no-10delta", action="store_true", help="use only ATM + 25-delta smile")
    ap.add_argument("--demo-smile", choices=["flat", "convex"], default="convex")
    ap.add_argument("--selftest", action="store_true")
    args = ap.parse_args()
    if args.selftest:
        selftest(); return

    has10 = not args.no_10delta
    results = []
    for tenor in [t.strip() for t in args.tenors.split(",") if t.strip()]:
        if args.source == "bloomberg":
            _log(f"[{tenor}] pulling Bloomberg ({'ATM+25d+10d' if has10 else 'ATM+25d'}) "
                 f"{args.start} -> {args.end} ...")
            df = fetch_bloomberg(tenor, args.start, args.end, has10)
            _log(f"[{tenor}] pulled shape={df.shape}; dates "
                 f"{df.index.min()} -> {df.index.max()}")
            if df.dropna(how="all").empty:
                raise SystemExit(f"[{tenor}] Bloomberg returned NO data. Check the Terminal/"
                                 f"blpapi session and tickers (run the standalone bdh test).")
        elif args.source == "csv":
            if not args.csv:
                raise SystemExit("--csv required with --source csv")
            df = load_csv(args.csv)
        else:
            df = make_demo_smile(convex=(args.demo_smile == "convex"))
        _log(f"[{tenor}] analyzing...")
        results.append(analyze_vr(df, tenor, has10))

    for r in results:
        report_vr(r)

    go, notes = evaluate_gate(results)
    print("\n" + "=" * 70)
    print(f"GATE (same thresholds as Step 1):  {'>>> GO <<<' if go else '>>> NO-GO <<<'}")
    print(f"PRE-REGISTERED KILL BAR: kill if every tenor has |VR mean|<0.03, |t|<2, "
          f"sign-unstable.")
    killed = all(abs(r["mean_overlap"]) < 0.03 and abs(r["t_overlap"]) < 2.0
                 and r["sub_consistent"] <= 2 for r in results)
    print(f"  -> {'HARD KILL the triangle, reallocate to event vol.' if killed else 'NOT auto-killed; inspect VR vs ATM delta and regime split.'}")
    if notes:
        print("Flags:")
        for n in notes:
            print("  - " + n)
    print("=" * 70)
    print("\nThe number that matters: does VR move the spread/t materially vs the ATM\n"
          "baseline printed above? If ATM and VR agree (both ~0, both unstable), the\n"
          "smile was not hiding anything -> kill. If VR diverges strongly, tighten the\n"
          "delta/strangle/forward conventions before trusting it.")

if __name__ == "__main__":
    main()




