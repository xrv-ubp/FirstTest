
#!/usr/bin/env python3
"""
fx_dispersion_step2.py
======================
STEP 2 (RESCUE TEST) of the EUR/USD/JPY triangle dispersion pipeline.

The Step 1 NO-GO used ATM-only implied correlation. ATM ignores the smile, and
the smile steepens in stress -- so the conditional/regime signal we saw could be
a *measurement artifact* rather than an edge. This script corrects that single
known measurement error and nothing else: it rebuilds implied correlation from
the variance-replicating (variance-swap) vol of each pair instead of the ATM vol.

Why this is legitimate and NOT data-mining:
  - r_cross = r_b1 + r_b2 exactly, so Var-swap strikes obey the same triangle:
        K_cross = K_b1 + K_b2 + 2 * rho_VR * sqrt(K_b1*K_b2)
    => rho_VR = (K_cross - K_b1 - K_b2) / (2 sqrt(K_b1*K_b2))
  - K_x is the model-free fair variance (Carr-Madan replication over the smile),
    the theoretically correct object that ATM only approximates.
  - We re-use the IDENTICAL Step 1 gate, regime split and sub-period test, so the
    comparison is apples-to-apples. The only thing that changed is ATM -> Var-swap.

Pre-registered kill bar (set before looking at the real output):
  If the VR unconditional spread is |mean| < 0.03 AND HAC |t| < 2 AND sign-unstable
  across halves  ->  HARD KILL the triangle, reallocate.

Caveats baked into the code (flagged, toggleable), because they affect the level:
  - Forward deltas (premium adjustment ignored). Matters more for JPY pairs.
  - Smile-strangle vs market-strangle BF convention (Bloomberg quotes broker BF).
  - F defaulted to spot (forward drift ignored). Fine for a kill/keep decision at
    1M/3M; tighten before trusting any GO.
These do not bias the flat-smile limit, which is the unit test below.
"""

from __future__ import annotations
import argparse
import numpy as np
import pandas as pd

# Standard-normal CDF (_Phi) and inverse-CDF (_Phi_inv) WITHOUT scipy.stats.
# Some Bloomberg/conda python environments ship scipy without a working
# scipy.stats, so we use scipy.special (ndtr/ndtri) and fall back to a pure
# numpy/stdlib implementation if even that is unavailable. Math is unchanged.
try:
    from scipy.special import ndtr as _Phi, ndtri as _Phi_inv          # preferred
except Exception:                                                       # pragma: no cover
    from math import erf as _merf
    _erf = np.vectorize(_merf)

    def _Phi(x):
        return 0.5 * (1.0 + _erf(np.asarray(x, dtype=float) / np.sqrt(2.0)))

    def _Phi_inv(p):  # Acklam rational approximation, ~1.15e-9 accuracy (scalar use)
        p = float(p)
        a = (-3.969683028665376e+01, 2.209460984245205e+02, -2.759285104469687e+02,
             1.383577518672690e+02, -3.066479806614716e+01, 2.506628277459239e+00)
        b = (-5.447609879822406e+01, 1.615858368580409e+02, -1.556989798598866e+02,
             6.680131188771972e+01, -1.328068155288572e+01)
        c = (-7.784894002430293e-03, -3.223964580411365e-01, -2.400758277161838e+00,
             -2.549732539343734e+00, 4.374664141464968e+00, 2.938163982698783e+00)
        d = (7.784695709041462e-03, 3.224671290700398e-01, 2.445134137142996e+00,
             3.754408661907416e+00)
        plow, phigh = 0.02425, 1 - 0.02425
        if p < plow:
            q = np.sqrt(-2 * np.log(p))
            return (((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / \
                   ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1)
        if p <= phigh:
            q = p - 0.5; r = q * q
            return (((((a[0]*r+a[1])*r+a[2])*r+a[3])*r+a[4])*r+a[5])*q / \
                   (((((b[0]*r+b[1])*r+b[2])*r+b[3])*r+b[4])*r+1)
        q = np.sqrt(-2 * np.log(1 - p))
        return -(((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / \
                ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1)

# reuse the Step 1 machinery so the test is identical except for rho construction
from fx_dispersion_step1 import (
    BASE1, BASE2, CROSS, TENOR_BDAYS, ANNUALIZATION, GATE,
    forward_realized, hac_mean, evaluate_gate,
)

import sys, time
def _log(msg):
    print(msg, file=sys.stderr, flush=True)

PAIRS = [BASE1, BASE2, CROSS]
SMILE_COLS = ["atm", "rr25", "bf25", "rr10", "bf10", "spot"]

def bbg_smile_tickers(tenor: str) -> dict:
    tk = {}
    for p in PAIRS:
        tk[f"{p}_atm"]  = f"{p}V{tenor} BGN Curncy"
        tk[f"{p}_rr25"] = f"{p}25R{tenor} BGN Curncy"
        tk[f"{p}_bf25"] = f"{p}25B{tenor} BGN Curncy"
        tk[f"{p}_rr10"] = f"{p}10R{tenor} BGN Curncy"
        tk[f"{p}_bf10"] = f"{p}10B{tenor} BGN Curncy"
        tk[f"{p}_spot"] = f"{p} Curncy"
    return tk

# ---------------------------------------------------------------------------
# Black-76 forward (undiscounted) option prices and the replication engine
# ---------------------------------------------------------------------------
def _d1d2(F, K, sig, T):
    s = sig * np.sqrt(T)
    d1 = (np.log(F / K) + 0.5 * s * s) / s
    return d1, d1 - s

def black_call_fwd(F, K, sig, T):
    d1, d2 = _d1d2(F, K, sig, T)
    return F * _Phi(d1) - K * _Phi(d2)

def black_put_fwd(F, K, sig, T):
    d1, d2 = _d1d2(F, K, sig, T)
    return K * _Phi(-d2) - F * _Phi(-d1)

def fwd_delta_strike(F, sigma, T, delta, is_call):
    """Strike at a given (unadjusted) forward delta magnitude."""
    d1 = _Phi_inv(delta) if is_call else _Phi_inv(1.0 - delta)
    return F * np.exp(0.5 * sigma ** 2 * T - d1 * sigma * np.sqrt(T))

def build_smile_points(F, T, atm, rr25, bf25, rr10=None, bf10=None):
    """Return (strikes, vols) from FX smile quotes. RR=call-put, BF=0.5(call+put)-atm."""
    pts = [(F * np.exp(0.5 * atm ** 2 * T), atm)]          # DNS ATM strike
    quotes = [(rr25, bf25, 0.25)]
    if rr10 is not None and bf10 is not None and np.isfinite(rr10) and np.isfinite(bf10):
        quotes.append((rr10, bf10, 0.10))
    for rr, bf, d in quotes:
        vc = atm + bf + 0.5 * rr
        vp = atm + bf - 0.5 * rr
        pts.append((fwd_delta_strike(F, vc, T, d, True), vc))
        pts.append((fwd_delta_strike(F, vp, T, d, False), vp))
    pts.sort()
    return np.array([p[0] for p in pts]), np.array([p[1] for p in pts])

def fair_variance(F, T, Ksmile, Vsmile, n_grid=300, width=7.0):
    """Carr-Madan / VIX-style model-free fair variance from a smile.
    Flat-vol wing extrapolation; forward (undiscounted) OTM prices."""
    sd = float(np.mean(Vsmile)) * np.sqrt(T)
    if not np.isfinite(sd) or sd <= 0 or not np.isfinite(F) or F <= 0:
        return np.nan
    # Additional validation for Ksmile and Vsmile
    if len(Ksmile) == 0 or len(Vsmile) == 0 or not np.isfinite(Ksmile).all() or not np.isfinite(Vsmile).all():
        return np.nan
    grid = np.linspace(F * np.exp(-width * sd), F * np.exp(width * sd), n_grid)
    # Ensure grid is valid
    if not np.isfinite(grid).all():
        return np.nan
    lm_grid = np.log(grid / F)
    lm_pts = np.log(Ksmile / F)
    vol_grid = np.interp(lm_grid, lm_pts, Vsmile)          # flat extrapolation outside wings
    Q = np.where(grid < F,
                 black_put_fwd(F, grid, vol_grid, T),
                 black_call_fwd(F, grid, vol_grid, T))
    dK = np.gradient(grid)
    integral = np.sum(Q / grid ** 2 * dK)
    below = grid[grid <= F]
    if below.size == 0:
        return np.nan
    K0 = below[-1]
    return (2.0 / T) * integral - (1.0 / T) * (F / K0 - 1.0) ** 2

# ---------------------------------------------------------------------------
# Data scaling and series construction
# ---------------------------------------------------------------------------
def scale_factor(atm_series: pd.Series) -> float:
    return 100.0 if atm_series.dropna().median() > 1.0 else 1.0

def compute_rho_vr(df: pd.DataFrame, tenor: str, has10: bool, use_forward_col=False):
    """Variance-replicating implied correlation series + the ATM rho for comparison."""
    N = TENOR_BDAYS[tenor]
    T = N / ANNUALIZATION
    cols = {}
    for p in PAIRS:
        sc = scale_factor(df[f"{p}_atm"])
        cols[p] = dict(
            atm=df[f"{p}_atm"] / sc, rr25=df[f"{p}_rr25"] / sc, bf25=df[f"{p}_bf25"] / sc,
            rr10=(df[f"{p}_rr10"] / sc) if has10 else None,
            bf10=(df[f"{p}_bf10"] / sc) if has10 else None,
            spot=df[f"{p}_spot"],
        )
    idx = df.index
    rho_vr = np.full(len(idx), np.nan)
    a1 = cols[BASE1]["atm"].values; a2 = cols[BASE2]["atm"].values; ac = cols[CROSS]["atm"].values
    rho_atm = (ac ** 2 - a1 ** 2 - a2 ** 2) / (2 * a1 * a2)

    _log(f"  [{tenor}] computing variance-replicating series over {len(idx):,} dates...")
    t0 = time.time()
    skipped = 0
    for i in range(len(idx)):
        if i and i % 1000 == 0:
            _log(f"     {i:,}/{len(idx):,}  ({time.time()-t0:.0f}s)")
        try:
            K = {}
            for p in PAIRS:
                c = cols[p]
                atm = c["atm"].iat[i]; F = c["spot"].iat[i]
                rr25 = c["rr25"].iat[i]; bf25 = c["bf25"].iat[i]
                # require the core ATM+25d smile and spot to be finite for this date
                if not (np.isfinite(atm) and atm > 0 and np.isfinite(F) and F > 0
                        and np.isfinite(rr25) and np.isfinite(bf25)):
                    raise ValueError
                Ksm, Vsm = build_smile_points(
                    F, T, atm, rr25, bf25,
                    c["rr10"].iat[i] if has10 else None,
                    c["bf10"].iat[i] if has10 else None)
                k = fair_variance(F, T, Ksm, Vsm)
                if not np.isfinite(k) or k <= 0:
                    raise ValueError
                K[p] = k
            rho_vr[i] = (K[CROSS] - K[BASE1] - K[BASE2]) / (2 * np.sqrt(K[BASE1] * K[BASE2]))
        except Exception:
            skipped += 1
            continue
    if skipped:
        _log(f"  [{tenor}] skipped {skipped:,}/{len(idx):,} dates with non-finite smile inputs")
    return pd.Series(rho_vr, index=idx, name="rho_vr"), pd.Series(rho_atm, index=idx, name="rho_atm")

# ---------------------------------------------------------------------------
# Analysis (mirrors Step 1, swapping in rho_vr; also reports the ATM baseline)
# ---------------------------------------------------------------------------
def analyze_vr(df, tenor, has10):
    N = TENOR_BDAYS[tenor]
    df = df.dropna(subset=[f"{p}_atm" for p in PAIRS] + [f"{p}_spot" for p in PAIRS]).copy()
    rho_vr, rho_atm = compute_rho_vr(df, tenor, has10)
    rho_real, rv1, rv2, rvc = forward_realized(df, N)
    rho_real_tri = (rvc ** 2 - rv1 ** 2 - rv2 ** 2) / (2 * rv1 * rv2)

    P = pd.concat({"rho_vr": rho_vr, "rho_atm": rho_atm, "rho_real": rho_real,
                   "v1": df[f"{BASE1}_atm"] / scale_factor(df[f"{BASE1}_atm"])}, axis=1).dropna()
    P["spread_vr"] = P["rho_vr"] - P["rho_real"]
    P["spread_atm"] = P["rho_atm"] - P["rho_real"]

    oob = ((rho_vr < -1) | (rho_vr > 1)).sum() / max(rho_vr.notna().sum(), 1)
    m_vr, t_vr, n_vr = hac_mean(P["spread_vr"], maxlags=int(1.5 * N))
    m_no, t_no, _ = hac_mean(P["spread_vr"].iloc[::N], maxlags=1)
    m_atm, t_atm, _ = hac_mean(P["spread_atm"], maxlags=int(1.5 * N))

    q = P["v1"].quantile([1/3, 2/3]).values
    reg = pd.cut(P["v1"], [-np.inf, q[0], q[1], np.inf], labels=["low_vol", "mid_vol", "high_vol"])
    regime = P.groupby(reg, observed=True)["spread_vr"].mean()

    chunks = np.array_split(P["spread_vr"].values, GATE["n_subperiods"])
    sub_means = [float(np.nanmean(c)) for c in chunks]
    sub_consistent = sum(np.sign(m) == np.sign(m_vr) for m in sub_means)
    recon_err = (P["rho_real"] - rho_real_tri.reindex(P.index)).abs().mean()

    return dict(
        tenor=tenor, n=len(P),
        vr_mean=float(rho_vr.mean()), vr_med=float(rho_vr.median()),
        vr_min=float(rho_vr.min()), vr_max=float(rho_vr.max()),
        atm_mean_level=float(rho_atm.reindex(P.index).mean()),
        oob_frac=oob, recon_err=recon_err,
        mean_overlap=m_vr, t_overlap=t_vr, n_overlap=n_vr,
        mean_nonoverlap=m_no, t_nonoverlap=t_no,
        atm_spread=m_atm, atm_t=t_atm,
        regime=regime.to_dict(), sub_means=sub_means, sub_consistent=sub_consistent,
    )

def report_vr(r):
    print(f"\n================  TENOR {r['tenor']}  (VARIANCE-REPLICATING)  ================")
    print(f"observations (aligned):            {r['n']:,}")
